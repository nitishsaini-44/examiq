# ──────────────────────────────────────
#  ExamIQ — Root .gitignore
# ──────────────────────────────────────

# ─── Python / Backend ─────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# Virtual environments
venv/
.venv/
env/
.env

# Backend environment file (contains API keys)
backend/.env

# Uploaded files & analysis cache
backend/uploads/
backend/data/uploaded_papers.json
backend/data/analysis_result.json

# Model cache (sentence-transformers downloads)
.cache/

# ─── Node.js / Frontend ──────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js
frontend/.next/
frontend/out/
frontend/build/

# Frontend environment files
frontend/.env
frontend/.env.local
frontend/.env.production
frontend/.env*.local

# ─── IDE / Editor ─────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── OS Files ─────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
._*

# ─── Debug / Logs ─────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
pip-log.txt

# ─── Testing ──────────────────────────
coverage/
.coverage
htmlcov/
.pytest_cache/
.tox/

# ─── Misc ─────────────────────────────
*.pem
.vercel
*.tsbuildinfo
next-env.d.ts
